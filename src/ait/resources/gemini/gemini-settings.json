{
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"$GEMINI_PROJECT_DIR/.ait/adapters/gemini/gemini_hook.py\""
          }
        ]
      }
    ],
    "AfterTool": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"$GEMINI_PROJECT_DIR/.ait/adapters/gemini/gemini_hook.py\""
          }
        ]
      }
    ],
    "AfterToolFailure": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"$GEMINI_PROJECT_DIR/.ait/adapters/gemini/gemini_hook.py\""
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"$GEMINI_PROJECT_DIR/.ait/adapters/gemini/gemini_hook.py\""
          }
        ]
      }
    ]
  }
}
